<Window x:Class="StringFunctions.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="String Functions"
        Height="550"
        Width="850">

    <Grid Background="#F2F2F2">

        <Border Width="700"
                Height="450"
                Background="White"
                CornerRadius="15"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>

                <TextBlock Text="C# String Functions"
                           FontSize="24"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <TextBlock Text="Enter Input String"/>

                <TextBox x:Name="txtInput"
                         Height="30"
                         Margin="0,5,0,15"
                         Text="I am studing"/>

                <!-- Buttons -->
                <WrapPanel Margin="0,0,0,20">

                    <Button Content="Replace()"
                            Width="90"
                            Margin="5"
                            Click="Replace_Click"/>

                    <Button Content="StartsWith()"
                            Width="100"
                            Margin="5"
                            Click="StartsWith_Click"/>

                    <Button Content="EndsWith()"
                            Width="90"
                            Margin="5"
                            Click="EndsWith_Click"/>

                    <Button Content="Contains()"
                            Width="90"
                            Margin="5"
                            Click="Contains_Click"/>

                    <Button Content="ToUpper()"
                            Width="90"
                            Margin="5"
                            Click="Upper_Click"/>

                    <Button Content="ToLower()"
                            Width="90"
                            Margin="5"
                            Click="Lower_Click"/>

                    <Button Content="Split()"
                            Width="90"
                            Margin="5"
                            Click="Split_Click"/>

                    <Button Content="Join()"
                            Width="90"
                            Margin="5"
                            Click="Join_Click"/>

                    <Button Content="Null Check"
                            Width="90"
                            Margin="5"
                            Click="Null_Click"/>

                    <Button Content="IndexOf()"
                            Width="90"
                            Margin="5"
                            Click="IndexOf_Click"/>

                    <Button Content="LastIndexOf()"
                            Width="110"
                            Margin="5"
                            Click="LastIndexOf_Click"/>

                </WrapPanel>

                <TextBlock Text="Output"/>

                <TextBox x:Name="txtOutput"
                         Height="80"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         Background="LightGreen"
                         FontSize="16"/>

            </StackPanel>

        </Border>

    </Grid>
</Window>